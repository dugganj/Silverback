---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import heroImage from "../assets/silverback-hero.png";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <div class="hero-image">
          <Image
            src={heroImage}
            alt="A silverback gorilla developer at his desk"
          />
        </div>
        <div class="hero-text">
          <p>
            A senior developer's perspective on building software in the age of
            AI — practical lessons from the trenches, not the hype cycle. For
            developers and tech leads who want to think clearly about where AI
            actually helps.
          </p>
          <p>
            I don't know everything. In fact, I am learning as I go along. I
            promise to share steps on my journey. Including the mistakes.
          </p>
          <p><a href="/blog">Read the blog &rarr;</a></p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 2em;
  }
  .hero-image {
    flex: 0 0 auto;
    width: 45%;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .hero-text {
    flex: 1;
  }
  .hero-text h1 {
    font-size: 2.2em;
    margin-bottom: 0.5em;
  }
  @media (max-width: 720px) {
    .hero {
      flex-direction: column;
    }
    .hero-image {
      width: 100%;
    }
  }
</style>

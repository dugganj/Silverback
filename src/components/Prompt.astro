---
interface Props {
  label?: 'Prompt' | 'System' | 'User' | 'Assistant';
}
const { label = 'Prompt' } = Astro.props;
---
<div class="prompt-block">
  <span class="prompt-label">{label}</span>
  <div class="prompt-body">
    <slot />
  </div>
</div>

<style>
  .prompt-block {
    border-left: 3px solid #6366f1;
    background: #1e1e2e;
    border-radius: 0.375rem;
    margin: 1.5rem 0;
    overflow: hidden;
  }
  .prompt-label {
    display: block;
    background: #6366f1;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
  }
  .prompt-body {
    padding: 1rem 1.25rem;
    font-family: monospace;
    font-size: 0.9rem;
    white-space: pre-wrap;
    color: #cdd6f4;
  }
</style>
